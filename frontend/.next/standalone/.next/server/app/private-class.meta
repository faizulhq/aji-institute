{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/private-class/layout,_N_T_/private-class/page,_N_T_/private-class"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/private-class/__PAGE__",
    "/private-class",
    "/_index",
    "/_head"
  ]
}