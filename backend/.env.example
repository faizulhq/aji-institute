# Backend Environment Variables
# Copy file ini menjadi .env dan isi sesuai environment Anda

# Django Secret Key (harus diganti di production!)
SECRET_KEY=django-ajistat-secret-key-change-in-production-2026

# Mode debug (False di production)
DEBUG=True

# Midtrans Payment Gateway
MIDTRANS_IS_PRODUCTION=False
MIDTRANS_SERVER_KEY=SB-Mid-server-YOUR_SERVER_KEY
MIDTRANS_CLIENT_KEY=SB-Mid-client-YOUR_CLIENT_KEY

# Contoh untuk production:
# DEBUG=False
# MIDTRANS_IS_PRODUCTION=True
# MIDTRANS_SERVER_KEY=Mid-server-YOUR_PRODUCTION_KEY
# MIDTRANS_CLIENT_KEY=Mid-client-YOUR_PRODUCTION_KEY
